<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comment Board - VULNERABLE</title>
<style>
  body { font-family: Arial, sans-serif; margin: 40px; background: #fff5f5; }
  h1 { color: #c0392b; }
  .warning { background: #ffecec; border: 2px solid #e74c3c; padding: 10px; margin-bottom: 20px; border-radius: 5px; }
  .comment { border: 1px solid #ccc; padding: 10px; margin: 10px 0; border-radius: 5px; }
  .username { font-weight: bold; color: #333; }
  .date { font-size: 0.8em; color: #666; }
  form { margin: 20px 0; background: #fff; padding: 20px; border: 1px solid #ddd; border-radius: 5px; }
  input, textarea { width: 400px; margin: 5px 0; padding: 8px; border: 1px solid #ccc; border-radius: 3px; display: block; }
  button { margin-top: 10px; padding: 8px 16px; background: #e74c3c; color: white; border: none; border-radius: 3px; cursor: pointer; }
  .api-section { margin-top: 30px; }
</style>
</head>
<body>
  <h1>Comment Board (VULNERABLE)</h1>
  <div class="warning">
    <strong>Это учебное уязвимое приложение.</strong><br>
    Попробуйте ввести в комментарий: <code>&lt;script&gt;alert('XSS')&lt;/script&gt;</code>
  </div>

  <form action="/comment" method="POST">
    <div><label>Username:</label><input type="text" name="username" placeholder="Ваше имя"></div>
    <div><label>Comment:</label><textarea name="comment" rows="4" placeholder="Ваш комментарий"></textarea></div>
    <button type="submit">Post Comment</button>
  </form>

  <h2>Комментарии</h2>
  <% if (error) { %><div style="color:red"><%= error %></div><% } %>

  <% comments.forEach(function(c) { %>
  <div class="comment">
    <div class="username"><%- c.username %></div>
    <div><%- c.comment %></div>
    <div class="date"><%= c.created_at %></div>
  </div>
  <% }); %>

  <div class="api-section">
    <h3>API (JavaScript)</h3>
    <button onclick="loadComments()">Загрузить через API</button>
    <div id="api-result"></div>
  </div>

  <script>
    function loadComments() {
      fetch('/api/comments')
        .then(r => r.json())
        .then(data => {
          let html = '';
          data.forEach(c => {
            html += '<div style="border:1px solid #eee;padding:5px;margin:3px">' + c.comment + '</div>';
          });
          document.getElementById('api-result').innerHTML = html;
        });
    }
  </script>
</body>
</html>
